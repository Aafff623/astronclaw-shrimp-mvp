# AstronClaw Skill 环境变量示例
# 复制本文件为 .env 并填入真实值；.env 不要提交到 Git

# === AstronClaw 平台 ===
ASTRONCLAW_API_KEY=your_astronclaw_api_key_here
ASTRONCLAW_APP_ID=your_app_id_here
ASTRONCLAW_ENDPOINT=https://api.xfyun.cn
ASTRONCLAW_DEFAULT_LLM=spark-x1          # weekly-digest 用，推荐讯飞星火 X1 / Spark Lite

# === 推送渠道（weekly-digest 必需）===
# 飞书机器人 Webhook（交互卡片推送）
FEISHU_WEBHOOK_URL=

# 企业微信机器人 Webhook（markdown 推送）
WECHAT_WORK_WEBHOOK_URL=

# 钉钉机器人 Webhook（可选备用）
DINGTALK_WEBHOOK_URL=

# === Notion 集成（weekly-digest 写入数据库）===
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=                       # 32 位 UUID，去掉短横线

# === 可选订阅源 ===
# Twitter 列表 ID（如需抓 Twitter 列表，weekly-digest 默认未启用）
TW_LIST_ID=
TW_BEARER_TOKEN=

# === 运行环境 ===
LOG_LEVEL=info
TIMEZONE=Asia/Shanghai
