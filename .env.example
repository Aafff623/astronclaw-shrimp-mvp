# AstronClaw Skill 环境变量示例
# 复制本文件为 .env 并填入真实值；.env 不要提交到 Git

# === AstronClaw 平台 ===
ASTRONCLAW_API_KEY=your_astronclaw_api_key_here
ASTRONCLAW_APP_ID=your_app_id_here
ASTRONCLAW_ENDPOINT=https://api.xfyun.cn

# === 推送渠道（按需启用）===
# 飞书机器人 Webhook
FEISHU_WEBHOOK_URL=

# 企业微信机器人 Webhook
WECHAT_WORK_WEBHOOK_URL=

# 钉钉机器人 Webhook
DINGTALK_WEBHOOK_URL=

# === 外部数据源（按需填写）===
# 示例：arXiv / GitHub / 自定义 API
EXTERNAL_API_KEY=
EXTERNAL_API_ENDPOINT=

# === 运行环境 ===
LOG_LEVEL=info
TIMEZONE=Asia/Shanghai
